<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- CloudKit + Push entitlements are temporarily removed so the app provisions with a
     basic development profile. They live in git history (commit 829e06b) and get
     restored once the iCloud.com.lucianlabs.forgetmenot container is provisioned. -->
<plist version="1.0">
<dict>
	<!-- Local MCP server socket. Sandbox entitlements (not App-ID capabilities), so they
	     don't require provisioning-profile registration. -->
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
